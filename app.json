{
  "expo": {
    "name": "MeetstickExpo",
    "slug": "meetstick-expo",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "scheme": "meetstick",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meetstick.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#232323",
          "image": "./assets/app-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Fotoğraflarını ekleyebilmen için galeri erişimi gerekiyor.",
          "cameraPermission": "Fotoğraf çekebilmen için kamera erişimi gerekiyor."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "702c8aec-f37a-4765-8944-b9256d4d6f87"
      }
    },
    "owner": "osein"
  }
}
